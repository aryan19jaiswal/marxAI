# Copy this file to .env and adjust values as needed.
# .env is gitignored — these are local dev defaults only, never used in production.

POSTGRES_DB=marxai
POSTGRES_USER=marxai
POSTGRES_PASSWORD=marxai

MINIO_ROOT_USER=marxai
MINIO_ROOT_PASSWORD=marxai12345

# JWT_SECRET must be at least 32 chars (HS256 requires a 256-bit key). Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-of-at-least-32-characters
JWT_EXPIRATION_MS=86400000
