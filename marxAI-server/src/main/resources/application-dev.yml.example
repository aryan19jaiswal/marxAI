spring:
  datasource:
    url: jdbc:postgresql://localhost:5433/marxai
    username: marxai
    password: marxai
    driver-class-name: org.postgresql.Driver
  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: true
    properties:
      hibernate:
        format_sql: true
  flyway:
    enabled: true
    locations: classpath:db/migration
    baseline-on-migrate: true
  data:
    redis:
      host: localhost
      port: 6379

minio:
  url: http://localhost:9000
  access-key: marxai
  secret-key: marxai12345
  bucket: marxai-documents

qdrant:
  host: localhost
  rest-port: 6333
  grpc-port: 6334
  collection-name: marxai-chunks

gemini:
  api-key: YOUR_GEMINI_API_KEY
  embedding-model: gemini-embedding-001
  chat-model: gemini-2.0-flash
  chat-model-fast: gemini-2.0-flash-lite

jwt:
  secret: change-me-to-a-long-random-secret-of-at-least-32-characters
  expiration-ms: 86400000

# Day 17-18: Judge0 code execution (via RapidAPI)
# Sign up at https://rapidapi.com/judge0-official/api/judge0-ce and get your API key.
judge0:
  base-url: https://judge0-ce.p.rapidapi.com
  api-key: YOUR_JUDGE0_RAPIDAPI_KEY
  timeout-seconds: 15
